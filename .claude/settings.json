{
  "permissions": {
    "allow": ["Bash", "Read", "Write", "Edit", "Glob", "Grep", "WebFetch", "WebSearch", "Task", "Skill"],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(git push --force:*)",
      "Bash(dd if=/dev/zero:*)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Write(~/.claude/settings.json)"
    ]
  },
  "hooks": {
    "SessionStart": [{
      "hooks": [{
        "type": "command",
        "command": "python3 execution/brain.py last-session --quiet 2>/dev/null || true"
      }]
    }],
    "Stop": [{
      "hooks": [{
        "type": "agent",
        "agent": "maintainer"
      }]
    }]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "300000"
  }
}
